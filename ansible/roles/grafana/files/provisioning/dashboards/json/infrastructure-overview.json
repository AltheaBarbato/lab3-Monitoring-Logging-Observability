{
  "uid": "infra-overview",
  "title": "Infrastructure Overview",
  "tags": ["infrastructure"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum(up)", "legendFormat": "up" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color": "red","value": 0},{"color": "green","value": 3}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "CPU Usage %",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"yellow","value":60},{"color":"red","value":80}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Memory Usage %",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "Mem %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"yellow","value":70},{"color":"red","value":85}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Disk Usage %",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100", "legendFormat": "Disk %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"yellow","value":70},{"color":"red","value":85}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Usage Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "Mem %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network Traffic (bytes/sec)",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device=\"ens3\"}[2m])", "legendFormat": "rx" },
        { "expr": "rate(node_network_transmit_bytes_total{device=\"ens3\"}[2m])", "legendFormat": "tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "NGINX Requests/sec",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        { "expr": "rate(nginx_http_requests_total[2m])", "legendFormat": "req/s" },
        { "expr": "nginx_connections_active", "legendFormat": "active connections" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    }
  ],
  "schemaVersion": 36
}
