{
  "uid": "security-events",
  "title": "Security Events",
  "tags": ["security"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Failed SSH Logins (auth.log)",
      "description": "Cumulative count of 'Failed password' entries in /var/log/auth.log",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "node_failed_ssh_logins_total", "legendFormat": "failed logins" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"yellow","value":10},{"color":"red","value":50}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Alerts",
      "description": "Number of currently firing Prometheus alerts",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "legendFormat": "firing" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"red","value":1}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fail2Ban Jails Active",
      "description": "Number of Fail2Ban jail processes running (proxy metric via process count)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "count(node_systemd_unit_state{name=\"fail2ban.service\",state=\"active\"}) or vector(0)", "legendFormat": "fail2ban" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":0},{"color":"green","value":1}] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Failed SSH Login Attempts Over Time",
      "description": "Rate of new failed logins per minute. Spikes indicate brute-force or scanning activity.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "rate(node_failed_ssh_logins_total[5m]) * 60", "legendFormat": "failed logins/min" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":0},{"color":"red","value":1}] }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Firing Alerts Over Time",
      "description": "Any non-zero value means something went wrong. Each labeled series is a different alert.",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "ALERTS{alertstate=\"firing\"}", "legendFormat": "{{alertname}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    }
  ],
  "schemaVersion": 36
}
